# Authorized lab demonstration rules only.
# These examples are designed for safe, benign marker traffic in a controlled environment.

alert http any any -> any any (
    msg:"AUTHORIZED LAB Demo HTTP marker detected";
    flow:to_server,established;
    http.header;
    content:"X-Lab-Marker|3a 20|demo";
    nocase;
    classtype:misc-activity;
    sid:1000001;
    rev:1;
)

alert dns any any -> any any (
    msg:"AUTHORIZED LAB Demo DNS query for training.invalid";
    dns.query;
    content:"training.invalid";
    nocase;
    classtype:misc-activity;
    sid:1000002;
    rev:1;
)

alert tls any any -> any any (
    msg:"AUTHORIZED LAB Demo self-signed certificate observed";
    tls.cert_issuer;
    content:"CN=Authorized Lab CA";
    nocase;
    classtype:misc-activity;
    sid:1000003;
    rev:1;
)

